# -*- mode: ruby -*-
# vi: set ft=ruby :

# All Vagrant configuration is done below. The "2" in Vagrant.configure
# configures the configuration version (we support older styles for
# backwards compatibility). Please don't change it unless you know what
# you're doing.
Vagrant.configure("2") do |config|
  # The most common configuration options are documented and commented below.
  # For a complete reference, please see the online documentation at
  # https://docs.vagrantup.com.

  # Every Vagrant development environment requires a box. You can search for
  # boxes at https://vagrantcloud.com/search.
  config.vm.box = "bento/ubuntu-24.04"
  config.disksize.size = '100GB'

  # configure X11 forwarding
  config.ssh.forward_agent = true
  config.ssh.forward_x11 = true

  # Returns true if `GUI` environment variable is non empty.
  # Defaults to false
  def gui_enabled?
    !ENV.fetch('GUI', '').empty?
  end

  # Provider-specific configuration so you can fine-tune various
  # backing providers for Vagrant. These expose provider-specific options.
  # Example for VirtualBox:
  #
  config.vm.provider "virtualbox" do |vb|
    # Customize the amount of memory on the VM:
    vb.memory = "4096"
    vb.cpus = 2
    vb.gui = gui_enabled?
    vb.cpus = 2
    vb.memory = 4096

    # Graphics optimizations
    vb.customize ["modifyvm", :id, "--vram=128"]
    # vb.customize ["modifyvm", :id, "--accelerate-3d=on"]
    vb.customize ["setextradata", :id, "GUI/LastGuestSizeHint", "1280,720"]

    # Convenience features
    vb.customize ["modifyvm", :id, "--clipboard", "bidirectional"]
    vb.customize ["modifyvm", :id, "--draganddrop", "bidirectional"]

    # Network optimization
    vb.default_nic_type = "virtio"
  end
  #
  # View the documentation for the provider you are using for more
  # information on available options.

  # Enable provisioning with a shell script. Additional provisioners such as
  # Ansible, Chef, Docker, Puppet and Salt are also available. Please see the
  # documentation for more information about their specific syntax and use.
  # config.vm.provision "shell", inline: <<-SHELL
  #   # add scala source
  #   echo "deb https://dl.bintray.com/sbt/debian /" | tee -a /etc/apt/sources.list.d/sbt.list
  #   curl -sL "https://keyserver.ubuntu.com/pks/lookup?op=get&search=0x2EE0EA64E40A89B84B2DF73499E82A75642AC823" | apt-key add

  #   # system dependencies
  #   apt-get update
  #   DEBIAN_FRONTEND=noninteractive apt-get -y install xubuntu-core^ 
  #   DEBIAN_FRONTEND=noninteractive apt-get install -y xauth libxrender1 libxtst6 libxi6 jq sbt default-jre default-jdk virtualbox-guest-dkms virtualbox-guest-utils virtualbox-guest-x11 python3-distutils firefox autoconf flex bison parallel
  #   sed -i 's/allowed_users=.*$/allowed_users=anybody/' /etc/X11/Xwrapper.config
  # SHELL
    config.vm.provision "shell", inline: <<-SHELL

    # system dependencies
    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get -y install xubuntu-core lightdm
    Debian_FRONTEND=noninteractive apt-get install -y xauth libxrender1 libxtst6 libxi6 jq default-jre default-jdk firefox autoconf flex bison parallel unzip help2man cmake clang ninja-build
    sed -i 's/allowed_users=.*$/allowed_users=anybody/' /etc/X11/Xwrapper.config

    systemctl daemon-reload

    echo 'export DISPLAY=:0' >> /etc/environment
    echo 'export XDG_CURRENT_DESKTOP=GNOME' >> /etc/environment  
    echo 'export XDG_SESSION_TYPE=x11' >> /etc/environment

    # add scala source
    wget --no-verbose https://github.com/sbt/sbt/releases/download/v1.10.10/sbt-1.10.10.zip
    rm -rf sbt
    unzip -qq sbt-1.10.10.zip -d sbt
    ls sbt
    cp sbt/sbt/bin/sbt /bin/

  SHELL


  # install verilator
  config.vm.provision "shell", privileged: false, inline: <<-SHELL
    sudo apt-get install -y git make autoconf g++ flex bison libfl2 libfl-dev
    systemctl daemon-reload
    git clone https://github.com/verilator/verilator
cd verilator
git pull
git checkout v5.042
autoconf
./configure
make
sudo make install
  SHELL

  # user level installing
  config.vm.provision "shell", privileged: false, inline: <<-SHELL
    # new version of pip
    curl https://bootstrap.pypa.io/get-pip.py -o get-pip.py
    python3 get-pip.py
    rm get-pip.py
    source ~/.profile

     # python packages
    pip install flit numpy pandas seaborn matplotlib jupyter jupyterlab

    # uv
    curl -LsSf https://astral.sh/uv/install.sh | sh

    # rust and rust packages
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
    source $HOME/.cargo/env
    cargo install runt vcdump
  SHELL

  # user level provisioning
  config.vm.provision "shell", privileged: false, inline: <<-SHELL
    # install dahlia
    git clone https://github.com/cucapra/dahlia.git
    cd dahlia
    sbt assembly
    ln -s $(realpath fuse) ~/.local/bin/dahlia
    cd ~

    # install flame graph
    git clone https://github.com/brendangregg/FlameGraph.git

    # install calyx
    git clone https://github.com/calyxir/calyx.git
    cd calyx
    cargo build --all
    ln -s $(realpath ./target/debug/calyx) ~/.local/bin/calyx

    # install fud2
    cargo install --path fud2
    mkdir -p ~/.config
    echo 'dahlia = \"/home/vagrant/dahlia/fuse\"\n' > ~/.config/fud2.toml
    echo '[calyx]\nbase = \"/home/vagrant/calyx\"\n' >> ~/.config/fud2.toml
    echo '[flamegraph]\nscript = \"/home/vagrant/FlameGraph/flamegraph.pl\"\n' >> ~/.config/fud2.toml

    fud2 env init
    fud2 env activate

    # make sure Desktop exists
    mkdir -p ~/Desktop

    # petal eval directory
    cd ~/Desktop
    git clone https://github.com/calyxir/calyx-profiler-eval.git
    cd calyx-profiler-eval
    git checkout oopsla-26
    cd ~

    # # add Xilinx tools to the path
    # cat /vagrant/Xilinx_profile >> ~/.profile
    # cat /vagrant/Xilinx_profile >> ~/.bashrc

    # # move Xilinx installer to home
    # if [ -f "/vagrant/Xilinx_Unified_2019.2_1106_2127_Lin64.bin" ]; then
    #   cp /vagrant/Xilinx_Unified_2019.2_1106_2127_Lin64.bin ~
    # fi

    # # move Xilinx installer launcher to Desktop
    # if [ -f "/vagrant/Xilinx_installer.desktop" ]; then
    #   cp /vagrant/Xilinx_installer.desktop ~/Desktop
    # fi

    # make vagrant default user
    # if ! cat /etc/lightdm/lightdm-gtk-greeter.conf | grep "user-session="; then
    #    echo "user-session=vagrant" | sudo tee -a /etc/lightdm/lightdm-gtk-greeter.conf
    # fi

    # allow user to access shared folders
    sudo adduser $(whoami) vboxsf
  SHELL
end
